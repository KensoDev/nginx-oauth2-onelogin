# OneLogin Configuration
ONELOGIN_SUBDOMAIN=your-subdomain
ONELOGIN_CLIENT_ID=your-client-id
ONELOGIN_CLIENT_SECRET=your-client-secret

# Application Host (for OAuth2 callback)
APP_HOST=localhost

# Cookie Secret (generate with: python -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())')
COOKIE_SECRET=changeme-generate-a-random-32-byte-string
